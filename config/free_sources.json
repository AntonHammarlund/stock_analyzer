{
  "watchlist": {
    "enabled": true,
    "file": "data/watchlist.csv",
    "max_size": 25,
    "auto_seed": {
      "enabled": true,
      "from_portfolio": true,
      "from_top_picks": true,
      "fallback_symbols": ["AAPL", "MSFT", "AMZN", "GOOGL", "META", "NVDA", "TSLA", "JPM", "V", "XOM"]
    },
    "providers": {
      "alpha_vantage": {
        "enabled": true,
        "api_key_env": "ALPHAVANTAGE_API_KEY",
        "function": "TIME_SERIES_DAILY",
        "outputsize": "compact"
      },
      "marketstack": {
        "enabled": false,
        "api_key_env": "MARKETSTACK_API_KEY",
        "endpoint": "https://api.marketstack.com/v1/eod/latest"
      }
    },
    "default_provider": "alpha_vantage"
  }
}
